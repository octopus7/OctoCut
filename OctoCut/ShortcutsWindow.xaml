<Window x:Class="OctoCut.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키"
        Width="520"
        Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="128"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="64"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="32"/>
                <RowDefinition Height="48"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="Enter"/>
            <TextBlock x:Name="EnterActionText" Grid.Row="0" Grid.Column="1" Text="재생 / 일시정지"/>

            <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="Space"/>
            <TextBlock x:Name="SpaceActionText" Grid.Row="1" Grid.Column="1" Text="재생 시작 / 다시 누르면 시작 위치로 돌아가 정지" TextWrapping="Wrap"/>

            <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="S"/>
            <TextBlock x:Name="SplitActionText" Grid.Row="2" Grid.Column="1" Text="현재 위치 분할"/>

            <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="Delete"/>
            <TextBlock x:Name="DeleteActionText" Grid.Row="3" Grid.Column="1" Text="선택 클립 삭제"/>

            <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="SemiBold" Text="← / →"/>
            <TextBlock x:Name="FrameStepActionText" Grid.Row="4" Grid.Column="1" Text="이전 / 다음 프레임"/>

            <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="SemiBold" Text="F12"/>
            <TextBlock x:Name="CaptureActionText" Grid.Row="5" Grid.Column="1" Text="현재 프레임을 클립보드로 복사"/>
        </Grid>

        <Button x:Name="CloseButton"
                Grid.Row="1"
                Width="84"
                HorizontalAlignment="Right"
                Content="닫기"
                IsCancel="True"/>
    </Grid>
</Window>
