<Window x:Class="OctoCut.FfmpegMissingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFmpeg 필요"
        Width="500"
        Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Text="렌더링에는 FFmpeg가 필요합니다. 현재 설정과 PATH에서 ffmpeg.exe를 찾지 못했습니다. 다운로드 페이지를 열거나 이미 설치된 ffmpeg.exe 경로를 직접 지정할 수 있습니다."/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="126"
                    Margin="0,0,8,0"
                    Content="다운로드 열기"
                    Click="Download_Click"/>
            <Button Width="126"
                    Margin="0,0,8,0"
                    Content="경로 지정"
                    Click="Browse_Click"/>
            <Button Width="84"
                    Content="취소"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
