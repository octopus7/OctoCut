<Window x:Class="OctoCut.FfmpegMissingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFmpeg 설치 필요"
        Width="680"
        Height="230"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Text="OctoCut 실행에는 FFmpeg가 필요합니다. 현재 설정과 PATH에서 ffmpeg.exe를 찾지 못했습니다. WinGet으로 바로 설치하거나, 이미 설치된 ffmpeg.exe 경로를 직접 지정하세요. 취소하면 OctoCut이 종료됩니다."/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="WingetInstallButton"
                    Width="112"
                    Margin="0,0,8,0"
                    Content="winget 설치"
                    Click="WingetInstall_Click"/>
            <Button Width="126"
                    Margin="0,0,8,0"
                    Content="공식 다운로드"
                    Click="Download_Click"/>
            <Button Width="126"
                    Margin="0,0,8,0"
                    Content="경로 지정"
                    Click="Browse_Click"/>
            <Button Width="84"
                    Content="취소"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
