<Window x:Class="OctoCut.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:OctoCut.Controls"
        mc:Ignorable="d"
        Title="OctoCut" Height="760" Width="1180" MinHeight="680" MinWidth="980"
        Background="#F4F6F8"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="영상 열기(_O)..." Click="OpenVideo_Click"/>
                <Separator/>
                <MenuItem Header="설정(_S)..." Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="끝내기(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="렌더(_R)" SubmenuOpened="RenderMenu_SubmenuOpened">
                <MenuItem x:Name="RenderCopyMenuItem"
                          Header="무인코딩 렌더(_C)..."
                          Click="RenderCopy_Click"
                          ToolTip="가능한 경우 FFmpeg stream copy로 새 인코딩 없이 렌더합니다."/>
                <MenuItem x:Name="RenderEncodeMenuItem"
                          Header="인코딩 렌더(_E)..."
                          Click="RenderEncode_Click"
                          ToolTip="H.264/AAC로 새 파일을 인코딩합니다."/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FfmpegStatusText" Foreground="#57606A"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <ProgressBar x:Name="BusyProgress"
                             Width="180"
                             Height="12"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="190"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#101318"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1">
                <MediaElement x:Name="Player"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="Uniform"
                              MediaOpened="Player_MediaOpened"
                              MediaEnded="Player_MediaEnded"/>
            </Border>

            <Grid Grid.Row="1" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="VideoNameText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="영상 없음"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="VideoPathText"
                               Margin="0,3,0,0"
                               Foreground="#57606A"
                               Text="파일을 선택하세요."
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="12,0,0,0">
                    <Button x:Name="OpenButton"
                            Width="96"
                            Margin="0,0,8,0"
                            Content="영상 열기"
                            Click="OpenVideo_Click"/>
                    <Button x:Name="PlayPauseButton"
                            Width="96"
                            Margin="0,0,8,0"
                            Content="재생"
                            ToolTip="재생/일시정지 (Enter)"
                            Click="PlayPause_Click"/>
                    <Button x:Name="SplitButton"
                            Width="128"
                            Margin="0,0,8,0"
                            Content="현재 위치 분할"
                            ToolTip="현재 위치 분할 (S)"
                            Click="Split_Click"/>
                    <Button x:Name="RemoveClipButton"
                            Width="112"
                            Margin="0,0,8,0"
                            Content="선택 삭제"
                            Click="RemoveClip_Click"/>
                    <ToggleButton x:Name="RippleDeleteToggle"
                                  Width="32"
                                  Height="28"
                                  Margin="0,0,8,0"
                                  IsChecked="True"
                                  Click="RippleDeleteToggle_Click"
                                  ToolTip="잔물결 삭제: 삭제로 생긴 빈 구간을 뒤 클립이 앞으로 당겨 붙여 메웁니다.">
                        <Viewbox Width="20" Height="18">
                            <Canvas Width="28" Height="24">
                                <Path Stroke="#24292F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M14,3 C10,6 18,9 14,12 C10,15 18,18 14,21"/>
                                <Path Fill="#0969DA"
                                      Data="M12,12 L7,7 L7,10 L5,10 L5,14 L7,14 L7,17 Z"/>
                                <Path Fill="#0969DA"
                                      Data="M16,12 L21,7 L21,10 L23,10 L23,14 L21,14 L21,17 Z"/>
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>
                    <TextBlock x:Name="PositionText"
                               MinWidth="180"
                               VerticalAlignment="Center"
                               TextAlignment="Right"
                               Text="00:00.000 / 00:00.000"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="#FFFFFF"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1"
                    ClipToBounds="True">
                <ScrollViewer x:Name="TimelineScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              SizeChanged="TimelineScroll_SizeChanged">
                    <controls:TimelineView x:Name="Timeline"
                                           Height="170"
                                           MinWidth="900"
                                           Focusable="True"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
